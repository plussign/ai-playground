# Ignore everything by default.
*

# Keep directories traversable so allowed files inside them can be included.
!*/

# Keep this file tracked.
!.gitignore

# Allow only the requested file types.
!*.py
!*.md
!*.txt
!*.csv
!*.json

# Allow C#/.NET project source under tts_client.
!tts_client/
!tts_client/**

# Keep C# project/source files trackable.
!*.sln
!*.cs
!*.csproj
!*.xaml
!*.resx
!*.props
!*.targets
!*.appxmanifest
!*.manifest
!*.config
!*.svg

# Ignore .NET/Visual Studio build artifacts for tts_client.
tts_client/bin/
tts_client/obj/
tts_client/.vs/
tts_client/TestResults/
tts_client/**/bin/
tts_client/**/obj/
tts_client/**/TestResults/

# Ignore common user-specific files for C# tooling.
tts_client/**/*.user
tts_client/**/*.suo
tts_client/**/*.userosscache
tts_client/**/*.sln.docstates

# Ignore Entire Models Directory
models/
*db/
ASR/Qwen/**
