{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tts_client: debug构建",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/tts_client/TtsClient.csproj",
        "-f",
        "net9.0-windows10.0.19041.0",
        "-c",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build",
      "detail": "为 VS Code 调试器构建 Debug 版本。"
    },
    {
      "label": "tts_client: release构建",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/tts_client/TtsClient.csproj",
        "-f",
        "net9.0-windows10.0.19041.0",
        "-c",
        "Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "detail": "为 VS Code 调试器构建 Release 版本。"
    },
    {
      "label": "tts_client: debug运行",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/tts_client/TtsClient.csproj",
        "-t:Run",
        "-f",
        "net9.0-windows10.0.19041.0",
        "-c",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "以 Debug 配置运行 MAUI TTS 客户端。"
    },
    {
      "label": "tts_client: release运行",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/tts_client/TtsClient.csproj",
        "-t:Run",
        "-f",
        "net9.0-windows10.0.19041.0",
        "-c",
        "Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "detail": "以 Release 配置运行 MAUI TTS 客户端。"
    },
    {
      "label": "tts_client: 普通发布",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/tts_client/TtsClient.csproj",
        "-f",
        "net9.0-windows10.0.19041.0",
        "-c",
        "Release",
        "-r",
        "win-x64",
        "/p:PublishSingleFile=true",
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "detail": "生成常规 Release 发布产物。"
    },
    {
      "label": "tts_client: 裁剪发布",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/tts_client/TtsClient.csproj",
        "-f",
        "net9.0-windows10.0.19041.0",
        "-c",
        "Release",
        "-r",
        "win-x64",
        "/p:PublishSingleFile=true",
        "/p:PublishTrimmed=true",
        "/p:TrimMode=partial"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "detail": "生成启用程序集裁剪的 Release 发布产物。"
    }
  ]
}